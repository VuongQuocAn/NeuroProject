# Backend database
# Local PowerShell run outside Docker can use localhost instead of db.
DATABASE_URL=postgresql://admin:password123@localhost:5432/neuro_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Object storage. For local Docker use localhost:9000 and MINIO_SECURE=false.
# For Cloudflare R2 use: <account_id>.r2.cloudflarestorage.com and MINIO_SECURE=true.
MINIO_URL=localhost:9000
MINIO_ACCESS_KEY=your_s3_or_r2_access_key
MINIO_SECRET_KEY=your_s3_or_r2_secret_key
MINIO_SECURE=false
MINIO_REGION=auto

# Frontend/CORS. In production set these to your Vercel URL.
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT signing key. Use a long random value in production.
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini text explanation for Classification XAI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# Hugging Face API token for query embedding.
# Required: backend uses HF Inference API for BAAI/bge-m3 query vectors.
HF_API_TOKEN=your_huggingface_api_token_here
# Leave empty to use:
# https://router.huggingface.co/hf-inference/models/BAAI/bge-m3/pipeline/feature-extraction
HF_EMBEDDING_API_URL=

# Rerank top dense child chunks before sending top 3 contexts to Gemini.
HF_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
HF_RERANKER_API_URL=

# Frontend (Vercel)
NEXT_PUBLIC_API_URL=http://localhost:8000
